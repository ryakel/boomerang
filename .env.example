# Server port (default: 3001)
PORT=3001

# SQLite database path (default: /data/boomerang.db in Docker, ./boomerang.db locally)
# DB_PATH=/data/boomerang.db

# Anthropic API key (optional — users can add their own in Settings)
# ANTHROPIC_API_KEY=sk-ant-...

# Notion integration token (optional — users can add their own in Settings)
# NOTION_INTEGRATION_TOKEN=ntn_...

# Trello credentials (optional — users can add their own in Settings)
# Get your API key and secret at https://trello.com/power-ups/admin
# TRELLO_API_KEY=your_api_key
# TRELLO_SECRET=your_secret
