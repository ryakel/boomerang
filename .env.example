# Server port (default: 3001)
PORT=3001

# SQLite database path (default: /data/boomerang.db in Docker, ./boomerang.db locally)
# DB_PATH=/data/boomerang.db

# Anthropic API key (optional — users can add their own in Settings)
# ANTHROPIC_API_KEY=sk-ant-...

# Notion integration token (optional — users can add their own in Settings)
# NOTION_INTEGRATION_TOKEN=ntn_...

# Trello credentials (optional — users can add their own in Settings)
# Get your API key and secret at https://trello.com/power-ups/admin
# TRELLO_API_KEY=your_api_key
# TRELLO_SECRET=your_secret

# Google Calendar OAuth credentials (optional — users can add their own in Settings)
# Create at https://console.cloud.google.com/apis/credentials (enable Calendar API first)
# GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your_client_secret

# 17track API key for package tracking (optional — users can add their own in Settings)
# Free tier: 100 queries/day. Get a key at https://api.17track.net
# TRACKING_API_KEY=your_17track_key

# Pushover application token used as fallback if not set in Settings UI (optional)
# Per-user keys are still required — this only avoids re-entering the app token
# if you're the only user. Get a token at https://pushover.net (create an app).
# PUSHOVER_DEFAULT_APP_TOKEN=your_app_token

# Public URL where Boomerang is reachable (optional but recommended)
# Used to build deep-link URLs in notifications so tapping opens the relevant
# task directly. Without this, notifications still send but aren't tappable.
# PUBLIC_APP_URL=https://boomerang.example.com

# USPS direct tracking API (optional — used instead of 17track for USPS packages)
# Register at https://developers.usps.com and create an app with Tracking API access
# USPS_CLIENT_ID=your_consumer_key
# USPS_CLIENT_SECRET=your_consumer_secret

# --- Authentication (opt-in; for public / externally-hosted deployments) ---
# Boomerang ships with NO auth (single-user, trusted-machine threat model).
# Setting either AUTH_PASSWORD or AUTH_PASSWORD_HASH turns ON a login gate over
# every /api route. Generate both values below with:
#   node scripts/auth-setup.js [your-password]
#
# Browser login: password -> httpOnly session cookie. Prefer the hashed form so
# the plaintext password is never stored in the environment.
# AUTH_PASSWORD_HASH='scrypt$<saltHex>$<hashHex>'
# AUTH_PASSWORD=your_plaintext_password   # simpler alternative to the hash
#
# Machine/API access (iOS Shortcut, future native app): a static token sent as
# `Authorization: Bearer <token>` or `x-api-token: <token>`.
# API_TOKEN=long_random_hex_token
#
# Force the Secure flag on the session cookie. Auto-detected from
# X-Forwarded-Proto behind a TLS proxy (trust proxy is on); set to 1 to force,
# 0 to disable (e.g. plain-HTTP localhost testing).
# COOKIE_SECURE=1
